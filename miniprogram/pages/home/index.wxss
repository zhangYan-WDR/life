.home-page {
  position: relative;
  padding-bottom: 48rpx;
}

/* ===== 顶部渐变 ===== */
.home-gradient {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 400rpx;
  border-radius: 0 0 48rpx 48rpx;
  background:
    radial-gradient(circle at 80% 20%, rgba(255, 190, 130, 0.25), transparent 40%),
    linear-gradient(155deg, #4a3028 0%, #6a4838 40%, #8a6850 80%, #a08068 100%);
}

/* ===== 通用 z-index ===== */
.hero-panel,
.status-card,
.summary-section,
.section-panel {
  position: relative;
  z-index: 1;
}

.status-card {
  margin-bottom: 24rpx;
}

/* ===== Hero 毛玻璃面板 ===== */
.hero-panel {
  margin-bottom: 24rpx;
}

.hero-glass {
  padding: 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  color: #ffffff;
}

.hero-eyebrow {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 4rpx;
}

.family-name {
  margin-top: 16rpx;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.8);
}

.invite-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.12);
}

.invite-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.invite-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.invite-code {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
}

.invite-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
}

/* ===== 库存摘要 1+2 ===== */
.summary-section {
  margin-bottom: 24rpx;
}

.summary-big {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(120, 80, 50, 0.06);
  margin-bottom: 16rpx;
}

.summary-big-left {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.summary-number {
  font-size: 56rpx;
  font-weight: 700;
  color: #4a3028;
}

.summary-unit {
  font-size: 26rpx;
  color: #8a7a6e;
}

.summary-big-label {
  font-size: 24rpx;
  color: #a09080;
}

.summary-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.summary-small {
  padding: 24rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(120, 80, 50, 0.05);
}

.warn-card {
  background: linear-gradient(160deg, #fffaf0 0%, #fff4e6 100%);
}

.danger-card {
  background: linear-gradient(160deg, #fff8f6 0%, #fef0f0 100%);
}

.small-number {
  font-size: 42rpx;
  font-weight: 700;
  color: #4a3028;
}

.warn-num {
  color: #d07830;
}

.danger-num {
  color: #c84848;
}

.small-label {
  margin-top: 6rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #5a4a40;
}

.small-hint {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #b0a090;
}

/* ===== 通用 Section 面板 ===== */
.section-panel {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 24rpx rgba(120, 80, 50, 0.05);
}

.panel-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

/* ===== 成员列表 ===== */
.members {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.member-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: #faf7f3;
  transition: transform 0.15s ease;
}

.member-card:active {
  transform: scale(0.98);
}

.member-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e8a878 0%, #d88060 100%);
  color: #ffffff;
  text-align: center;
  line-height: 68rpx;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.member-meta {
  min-width: 0;
}

.member-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3a2a20;
}

.member-role {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #a09080;
}

/* ===== 工作台 ===== */
.action-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  transition: transform 0.18s ease;
}

.action-card:active {
  transform: scale(0.97);
}

.action-fridge {
  background: linear-gradient(135deg, #f0f4ff 0%, #e4ecff 100%);
}

.action-ingredients {
  background: linear-gradient(135deg, #fff6ee 0%, #ffecda 100%);
}

.action-emoji {
  font-size: 44rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.action-content {
  min-width: 0;
}

.action-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3a2a20;
}

.action-text {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8a7a6e;
  line-height: 1.6;
}

.subscribe-btn {
  margin-top: 18rpx;
}

.retry-btn {
  margin-top: 18rpx;
}
