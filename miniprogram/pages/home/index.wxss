.home-head {
  background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 100%);
  color: #ffffff;
}

.status-card {
  margin-bottom: 24rpx;
}

.family-name {
  font-size: 44rpx;
  font-weight: 700;
}

.members {
  margin-top: 26rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.member {
  min-width: 180rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.12);
}

.member-name {
  font-size: 28rpx;
  font-weight: 600;
}

.member-role {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.8;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.summary-card {
  text-align: center;
}

.summary-card.warning {
  background: #fff7ed;
}

.summary-card.danger {
  background: #fff1f2;
}

.metric {
  font-size: 46rpx;
  font-weight: 700;
}

.metric-label {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
}

.quick-actions {
  margin-top: 24rpx;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.action {
  width: 100%;
}

.subscribe-btn {
  margin-top: 18rpx;
}

.retry-btn {
  margin-top: 18rpx;
}
