.meal-detail-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 48rpx;
}

/* ===== Hero ===== */
.hero-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ffd8b8 0%, #f5b888 50%, #e89060 100%);
  color: #ffffff;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(208, 130, 80, 0.2);
}

.hero-decor {
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-emoji {
  font-size: 56rpx;
}

.hero-content {
  flex: 1;
  min-width: 0;
}

.hero-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #4a2818;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-status {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.hero-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(74, 40, 24, 0.75);
}

.hero-note {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(74, 40, 24, 0.7);
}

/* ===== 状态徽章 ===== */
.status-pending {
  background: #fff2df;
  color: #b46b2f;
}

.status-approved {
  background: #edf7e8;
  color: #4d8a39;
}

.status-rejected {
  background: #fdecec;
  color: #c34d4d;
}

/* ===== 分组 ===== */
.form-group {
  display: flex;
  flex-direction: column;
}

.group-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.group-bar {
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #e8845a 0%, #d4603e 100%);
}

.group-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a3828;
}

.group-count {
  margin-left: auto;
  font-size: 22rpx;
  color: #b0a090;
}

.section-card {
  padding: 8rpx 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 24rpx rgba(120, 80, 50, 0.05);
}

/* ===== 列表行 ===== */
.detail-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5efe8;
}

.detail-row:last-child {
  border-bottom: none;
}

.ing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e8a878 0%, #d88060 100%);
  flex-shrink: 0;
}

.detail-name {
  flex: 1;
  font-size: 28rpx;
  color: #2d2118;
}

.detail-value {
  font-size: 26rpx;
  color: #b07050;
  font-weight: 500;
}

/* ===== 表态行 ===== */
.response-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 2rpx solid #f5efe8;
}

.response-row:last-child {
  border-bottom: none;
}

.response-main {
  flex: 1;
  min-width: 0;
}

.response-comment {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #8a7869;
}

.response-decision {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.decision-pending {
  background: #fff1dd;
  color: #b36d33;
}

.decision-approved {
  background: #edf7e8;
  color: #4d8a39;
}

.decision-rejected {
  background: #fdecec;
  color: #c34d4d;
}

/* ===== 表态卡 ===== */
.respond-card {
  padding: 22rpx 24rpx;
}

.comment-box {
  width: 100%;
  min-height: 140rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #faf7f3;
  font-size: 28rpx;
  color: #2d2118;
  line-height: 1.6;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

/* ===== 缺料行 ===== */
.gap-row {
  padding: 22rpx 0;
  border-bottom: 2rpx solid #f5efe8;
}

.gap-row:last-child {
  border-bottom: none;
}

.gap-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.gap-status {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.gap-sufficient {
  background: #edf7e8;
  color: #4d8a39;
}

.gap-insufficient {
  background: #fff2df;
  color: #b46b2f;
}

.gap-missing {
  background: #fdecec;
  color: #c34d4d;
}

.gap-progress {
  width: 100%;
  height: 10rpx;
  border-radius: 5rpx;
  background: #f0e8e0;
  overflow: hidden;
}

.gap-progress-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width 0.4s ease;
}

.gap-fill-sufficient {
  background: linear-gradient(90deg, #88c270 0%, #5a9c4a 100%);
}

.gap-fill-insufficient {
  background: linear-gradient(90deg, #f5b878 0%, #e8a050 100%);
}

.gap-fill-missing {
  background: linear-gradient(90deg, #e89090 0%, #c46060 100%);
}

.gap-meta {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #8a7869;
}

/* ===== 再来一次 ===== */
.again-btn {
  margin-top: 12rpx;
}
