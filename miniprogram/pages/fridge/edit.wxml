<view class="page-shell">
  <view class="card">
    <view class="label">选择食材</view>
    <picker range="{{catalog}}" range-key="name" value="{{sourceIndex}}" bindchange="onSourceChange">
      <view class="input picker">{{catalog[sourceIndex] ? catalog[sourceIndex].name : '请选择食材'}}</view>
    </picker>
    <button class="ghost-btn helper-btn" bindtap="goIngredients">先去维护家庭食材</button>

    <view class="label top-gap">数量</view>
    <input class="input" type="digit" value="{{quantity}}" data-field="quantity" bindinput="onFieldInput" />

    <view class="label top-gap">单位</view>
    <input class="input" value="{{unit}}" data-field="unit" bindinput="onFieldInput" />

    <view class="label top-gap">生产日期</view>
    <picker mode="date" value="{{producedAt}}" data-field="producedAt" bindchange="onDateChange">
      <view class="input picker">{{producedAt || '请选择生产日期'}}</view>
    </picker>

    <view class="label top-gap">到期日期</view>
    <picker mode="date" value="{{expiresAt}}" data-field="expiresAt" bindchange="onDateChange">
      <view class="input picker">{{expiresAt || '请选择到期日期'}}</view>
    </picker>

    <view class="label top-gap">存放位置</view>
    <input class="input" placeholder="例如：冷藏上层" value="{{location}}" data-field="location" bindinput="onFieldInput" />

    <view class="label top-gap">备注</view>
    <input class="input" placeholder="可记录品牌、口味等" value="{{note}}" data-field="note" bindinput="onFieldInput" />

    <button class="primary-btn save-btn" bindtap="saveItem">保存库存</button>
  </view>
</view>
