<view class="page-shell page-enter edit-page">
  <!-- 食材信息 -->
  <view class="form-group">
    <view class="group-header">
      <view class="group-bar"></view>
      <text class="group-title">食材信息</text>
    </view>
    <view class="form-card">
      <view class="field">
        <view class="field-label">选择食材</view>
        <ingredient-picker
          catalog="{{catalog}}"
          value="{{sourceId}}"
          selected-item="{{selectedItem}}"
          bind:change="onSourceChange"
        />
      </view>
      <view class="field-link" bindtap="goIngredients">
        <text>找不到？去维护家庭食材</text>
        <text class="link-arrow">›</text>
      </view>
      <view class="field-row">
        <view class="field field-half">
          <view class="field-label">数量</view>
          <input class="field-input" type="digit" value="{{quantity}}" data-field="quantity" bindinput="onFieldInput" placeholder="1" />
        </view>
        <view class="field field-half">
          <view class="field-label">单位</view>
          <input class="field-input" value="{{unit}}" data-field="unit" bindinput="onFieldInput" placeholder="个" />
        </view>
      </view>
    </view>
  </view>

  <!-- 日期信息 -->
  <view class="form-group">
    <view class="group-header">
      <view class="group-bar"></view>
      <text class="group-title">日期信息</text>
    </view>
    <view class="form-card">
      <view class="field">
        <view class="field-label">生产日期</view>
        <picker mode="date" value="{{producedAt}}" data-field="producedAt" bindchange="onDateChange">
          <view class="field-picker">
            <text class="picker-text {{producedAt ? '' : 'placeholder'}}">{{producedAt || '请选择生产日期'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
      <view class="field-divider"></view>
      <view class="field">
        <view class="field-label">到期日期</view>
        <picker mode="date" value="{{expiresAt}}" data-field="expiresAt" bindchange="onDateChange">
          <view class="field-picker">
            <text class="picker-text {{expiresAt ? '' : 'placeholder'}}">{{expiresAt || '请选择到期日期'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 存放信息 -->
  <view class="form-group">
    <view class="group-header">
      <view class="group-bar"></view>
      <text class="group-title">存放信息</text>
    </view>
    <view class="form-card">
      <view class="field">
        <view class="field-label">存放位置</view>
        <input class="field-input" placeholder="例如：冷藏上层" value="{{location}}" data-field="location" bindinput="onFieldInput" />
      </view>
      <view class="field-divider"></view>
      <view class="field">
        <view class="field-label">备注</view>
        <input class="field-input" placeholder="可记录品牌、口味等" value="{{note}}" data-field="note" bindinput="onFieldInput" />
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <button class="primary-btn save-btn" bindtap="saveItem">保存库存</button>
</view>
