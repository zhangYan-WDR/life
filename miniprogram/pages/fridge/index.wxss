.tab-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  background: #e2e8f0;
  color: #475569;
  border-radius: 999rpx;
  padding: 20rpx 0;
}

.tab-item.active {
  background: #2563eb;
  color: #ffffff;
}

.list-card {
  margin-bottom: 20rpx;
}

.item-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.item-name {
  font-size: 34rpx;
  font-weight: 600;
}

.item-meta {
  margin-top: 10rpx;
  color: #64748b;
}

.badge {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #e2e8f0;
  color: #334155;
}

.badge.EXPIRING {
  background: #ffedd5;
  color: #c2410c;
}

.badge.EXPIRED {
  background: #ffe4e6;
  color: #be123c;
}

.action-strip {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.mini-btn {
  flex: 1;
}

.danger-btn {
  color: #be123c;
}

.empty-card {
  margin-top: 12rpx;
}

.floating-btn {
  margin-top: 24rpx;
}
