.edit-page {
  padding-bottom: 48rpx;
}

/* ===== 分组 ===== */
.form-group {
  margin-bottom: 28rpx;
}

.group-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.group-bar {
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #e8845a 0%, #d4603e 100%);
}

.group-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a3828;
}

/* ===== 表单卡片 ===== */
.form-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 6rpx 24rpx rgba(120, 80, 50, 0.05);
}

.field {
  padding: 20rpx 0;
}

.field-label {
  font-size: 24rpx;
  color: #9a8a7e;
  margin-bottom: 12rpx;
}

.field-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: #faf7f3;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #2d2118;
  transition: border-color 0.2s ease, background 0.2s ease;
}

.field-input:focus {
  border-color: #e0845a;
  background: #fffcf9;
}

/* Picker */
.field-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 24rpx;
  background: #faf7f3;
  border-radius: 16rpx;
  transition: background 0.2s ease;
}

.field-picker:active {
  background: #f5f0ea;
}

.picker-text {
  font-size: 28rpx;
  color: #2d2118;
}

.picker-text.placeholder {
  color: #c0b0a0;
}

.picker-arrow {
  font-size: 36rpx;
  color: #c0b0a0;
  font-weight: 300;
}

/* 分隔线 */
.field-divider {
  height: 2rpx;
  background: #f5efe8;
  margin: 0;
}

/* 跳转链接 */
.field-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  font-size: 24rpx;
  color: #d07040;
  border-top: 2rpx solid #f5efe8;
}

.field-link:active {
  opacity: 0.7;
}

.link-arrow {
  font-size: 30rpx;
  font-weight: 300;
}

/* 并排字段 */
.field-row {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-top: 2rpx solid #f5efe8;
}

.field-half {
  flex: 1;
  padding: 0;
}

/* 保存按钮 */
.save-btn {
  margin-top: 12rpx;
}
