.page-shell {
  padding: 32rpx;
}

.loading-tip {
  text-align: center;
  color: #b08060;
  font-size: 28rpx;
  padding: 80rpx 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d2118;
  margin-bottom: 20rpx;
}

.members-card {
  padding: 8rpx 0;
  margin-bottom: 48rpx;
}

.member-row {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 20rpx;
  border-radius: 16rpx;
  transition: background 0.2s;
}

.member-row.checked {
  background: #fdf3ea;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e07830, #c84848);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-name {
  flex: 1;
  font-size: 30rpx;
  color: #2d2118;
}

.check-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #d4b898;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #e07830;
  font-weight: 700;
  background: #fff;
}

.member-row.checked .check-icon {
  background: #e07830;
  border-color: #e07830;
  color: #fff;
}

.start-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #e07830, #c84848);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(200, 72, 72, 0.3);
}

.start-btn:active {
  transform: scale(0.97);
}

.start-btn.disabled {
  opacity: 0.6;
}
