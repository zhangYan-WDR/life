.page-shell {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 40rpx 32rpx 80rpx;
  box-sizing: border-box;
  background: linear-gradient(160deg, #1a0e06 0%, #2d1a0a 60%, #3d2510 100%);
}

/* ===== 玩家行 ===== */
.players-row {
  display: flex;
  align-items: center;
  width: 100%;
  gap: 20rpx;
  margin-bottom: 48rpx;
}

.player-card {
  flex: 1;
  background: rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 2rpx solid rgba(255,255,255,0.08);
  transition: all 0.3s;
}

.player-card.active {
  background: rgba(224, 120, 48, 0.18);
  border-color: #e07830;
  box-shadow: 0 0 24rpx rgba(224, 120, 48, 0.3);
}

.player-avatar {
  font-size: 48rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.player-label {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
}

.player-turn-hint {
  font-size: 22rpx;
  color: #e07830;
  margin-top: 6rpx;
  min-height: 28rpx;
}

.vs-text {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.3);
}

/* ===== 桶场景 ===== */
.barrel-scene {
  position: relative;
  width: 320rpx;
  height: 380rpx;
  margin-bottom: 32rpx;
}

.barrel-scene.shaking {
  animation: barrel-shake 0.65s ease-in-out;
}

.barrel-scene.exploding {
  animation: barrel-explode 0.5s ease-out forwards;
}

/* ===== 木桶主体 ===== */
.barrel {
  position: absolute;
  inset: 0;
  /* 桶身：上窄下宽的梯形感，用 border-radius 模拟 */
  background: linear-gradient(180deg,
    #5a3010 0%,
    #7a4820 15%,
    #8a5828 50%,
    #7a4820 85%,
    #5a3010 100%
  );
  border-radius: 40rpx 40rpx 56rpx 56rpx / 24rpx 24rpx 40rpx 40rpx;
  overflow: hidden;
  box-shadow:
    inset -16rpx 0 32rpx rgba(0,0,0,0.4),
    inset 8rpx 0 16rpx rgba(255,200,100,0.08),
    0 16rpx 48rpx rgba(0,0,0,0.6);
}

/* 木纹条 */
.plank {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 3rpx;
  background: rgba(0,0,0,0.2);
}
.plank:nth-child(1) { left: 14%; }
.plank:nth-child(2) { left: 28%; }
.plank:nth-child(3) { left: 42%; }
.plank:nth-child(4) { left: 56%; }
.plank:nth-child(5) { left: 70%; }
.plank:nth-child(6) { left: 84%; }
.plank:nth-child(7) { left: 7%; background: rgba(255,200,100,0.06); }

/* 金属箍 */
.hoop {
  position: absolute;
  left: -4rpx;
  right: -4rpx;
  height: 18rpx;
  background: linear-gradient(180deg, #c8a040, #8a6820, #c8a040);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5), inset 0 1rpx 2rpx rgba(255,220,100,0.4);
  z-index: 2;
}
.hoop-top { top: 14%; }
.hoop-mid { top: 50%; transform: translateY(-50%); }
.hoop-bot { bottom: 14%; }

/* 桶顶椭圆 */
.barrel-top {
  position: absolute;
  top: -12rpx;
  left: 8rpx;
  right: 8rpx;
  height: 40rpx;
  background: linear-gradient(180deg, #9a6830, #6a4018);
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.4);
  z-index: 3;
}

/* ===== 剑孔 ===== */
.sword-slot {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 4;
}

.hole-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.6);
  border: 2rpx solid rgba(0,0,0,0.8);
  box-shadow: inset 0 2rpx 4rpx rgba(0,0,0,0.8);
}

/* ===== 剑 ===== */
.sword {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: sword-in 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.sword.fly-out {
  animation: sword-fly 0.6s ease-in forwards;
}

.sword-blade {
  width: 6rpx;
  height: 48rpx;
  background: linear-gradient(180deg, #e8e8f0, #a0a0b8, #c8c8d8);
  border-radius: 3rpx 3rpx 0 0;
  box-shadow: 1rpx 0 4rpx rgba(0,0,0,0.4);
}

.sword-guard {
  width: 24rpx;
  height: 7rpx;
  background: linear-gradient(90deg, #c8a040, #f0d060, #c8a040);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.4);
}

.sword-handle {
  width: 8rpx;
  height: 20rpx;
  background: linear-gradient(180deg, #6a3010, #4a2008, #6a3010);
  border-radius: 0 0 4rpx 4rpx;
  box-shadow: 1rpx 0 4rpx rgba(0,0,0,0.4);
}

/* ===== 爆炸裂缝 ===== */
.crack {
  position: absolute;
  top: 20%;
  width: 4rpx;
  height: 60%;
  background: rgba(255, 100, 0, 0.8);
  box-shadow: 0 0 12rpx rgba(255, 100, 0, 0.6);
  animation: crack-appear 0.3s ease-out forwards;
  z-index: 5;
}

.crack-left {
  left: 30%;
  transform: rotate(-8deg);
}

.crack-right {
  right: 30%;
  transform: rotate(8deg);
}

/* ===== 剩余提示 ===== */
.remaining-hint {
  font-size: 26rpx;
  color: rgba(255,255,255,0.4);
  margin-bottom: 48rpx;
  letter-spacing: 2rpx;
}

/* ===== 插剑按钮 ===== */
.stab-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 64rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #c84020, #8a2010);
  border-radius: 50rpx;
  box-shadow: 0 8rpx 32rpx rgba(200, 64, 32, 0.5), inset 0 2rpx 4rpx rgba(255,150,100,0.2);
}

.stab-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(200, 64, 32, 0.4);
}

.stab-btn.disabled {
  opacity: 0.5;
}

.stab-icon {
  font-size: 40rpx;
}

.stab-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

/* ===== 爆炸遮罩 ===== */
.explode-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.explode-content {
  background: linear-gradient(160deg, #2d1a0a, #1a0e06);
  border: 2rpx solid rgba(200, 64, 32, 0.4);
  border-radius: 32rpx;
  padding: 64rpx 80rpx;
  text-align: center;
  animation: pop-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 0 60rpx rgba(200, 64, 32, 0.3);
}

.explode-icon {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.explode-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #ff6040;
  margin-bottom: 16rpx;
}

.explode-loser {
  font-size: 36rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 48rpx;
}

.restart-btn {
  background: linear-gradient(135deg, #c84020, #8a2010);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 64rpx;
  border-radius: 48rpx;
  display: inline-block;
  box-shadow: 0 6rpx 20rpx rgba(200, 64, 32, 0.4);
}

.restart-btn:active {
  transform: scale(0.96);
}

/* ===== 动画 ===== */
@keyframes barrel-shake {
  0%,100% { transform: translateX(0) rotate(0deg); }
  10%      { transform: translateX(-18rpx) rotate(-4deg); }
  20%      { transform: translateX(18rpx) rotate(4deg); }
  30%      { transform: translateX(-14rpx) rotate(-3deg); }
  40%      { transform: translateX(14rpx) rotate(3deg); }
  50%      { transform: translateX(-10rpx) rotate(-2deg); }
  60%      { transform: translateX(10rpx) rotate(2deg); }
  75%      { transform: translateX(-6rpx) rotate(-1deg); }
  90%      { transform: translateX(4rpx); }
}

@keyframes barrel-explode {
  0%   { transform: scale(1); }
  30%  { transform: scale(1.08) rotate(-2deg); }
  60%  { transform: scale(0.96) rotate(1deg); }
  100% { transform: scale(1.02); filter: brightness(1.5); }
}

@keyframes sword-in {
  0%   { transform: translateY(-30rpx) scaleY(0.3); opacity: 0.5; }
  100% { transform: translateY(0) scaleY(1); opacity: 1; }
}

@keyframes sword-fly {
  0%   { transform: translateY(0) rotate(0deg); opacity: 1; }
  100% { transform: translateY(-120rpx) rotate(var(--fly-angle, 30deg)); opacity: 0; }
}

@keyframes crack-appear {
  0%   { height: 0; opacity: 0; }
  100% { height: 60%; opacity: 1; }
}

@keyframes pop-in {
  0%   { transform: scale(0.6); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
