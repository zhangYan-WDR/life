.touch-area {
  position: fixed;
  inset: 0;
  background: linear-gradient(155deg, #1a1008 0%, #2d1c10 50%, #3a2418 100%);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 等待提示 */
.hint-wrap {
  text-align: center;
  pointer-events: none;
}

.hint-icon {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 32rpx;
  animation: float 2s ease-in-out infinite;
}

.hint-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.hint-sub {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.hint-sub.warn {
  color: #e07830;
  margin-top: 12rpx;
}

/* 倒计时 */
.countdown-wrap {
  text-align: center;
  pointer-events: none;
}

.countdown-num {
  font-size: 240rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
  text-shadow: 0 0 60rpx rgba(224, 120, 48, 0.8);
  animation: countdown-pop 0.3s ease-out;
}

.countdown-hint {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 24rpx;
}

/* 结果 */
.result-wrap {
  text-align: center;
  pointer-events: none;
}

.result-title {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
}

.result-sub {
  font-size: 72rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 64rpx;
  animation: pop-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.reset-btn {
  display: inline-block;
  padding: 24rpx 80rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 48rpx;
  color: #fff;
  font-size: 30rpx;
  pointer-events: auto;
}

.reset-btn:active {
  background: rgba(255, 255, 255, 0.25);
}

/* 手指光圈 */
.finger-ring {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.3s, transform 0.2s;
}

.finger-ring.ring-pulse {
  animation: pulse 0.6s ease-in-out infinite alternate;
}

.finger-ring.ring-winner {
  animation: winner-burst 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  border-width: 0;
}

.finger-ring.ring-eliminated {
  animation: fade-out 0.4s ease-out forwards;
}

.finger-num {
  font-size: 40rpx;
  font-weight: 700;
}

/* 动画 */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-16rpx); }
}

@keyframes countdown-pop {
  0%   { transform: scale(1.4); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes pulse {
  0%   { transform: translate(-50%, -50%) scale(1); }
  100% { transform: translate(-50%, -50%) scale(1.15); }
}

@keyframes winner-burst {
  0%   { transform: translate(-50%, -50%) scale(1); }
  50%  { transform: translate(-50%, -50%) scale(1.6); }
  100% { transform: translate(-50%, -50%) scale(1.3); }
}

@keyframes fade-out {
  0%   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  100% { opacity: 0.2; transform: translate(-50%, -50%) scale(0.7); }
}

@keyframes pop-in {
  0%   { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
