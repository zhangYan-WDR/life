.page-shell {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 32rpx 80rpx;
  box-sizing: border-box;
}

/* 转盘区域 */
.wheel-section {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.pointer {
  font-size: 52rpx;
  color: #c84848;
  line-height: 1;
  margin-bottom: -8rpx;
  z-index: 2;
  filter: drop-shadow(0 4rpx 8rpx rgba(200, 72, 72, 0.4));
}

.wheel-container {
  width: 560rpx;
  height: 560rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(160, 100, 40, 0.25);
}

.wheel-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.wheel-placeholder {
  width: 100%;
  height: 100%;
  background: #f0e8e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #b08060;
}

.hidden-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 280px;
  height: 280px;
}

/* 转动按钮 */
.spin-btn {
  width: 480rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #e07830, #c84848);
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(200, 72, 72, 0.35);
  margin-bottom: 40rpx;
  letter-spacing: 2rpx;
}

.spin-btn:active {
  transform: scale(0.96);
}

.spin-btn.disabled {
  opacity: 0.5;
}

/* 参与者卡片 */
.members-card {
  width: 100%;
  padding: 32rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d2118;
  margin-bottom: 24rpx;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.member-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.member-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.member-name {
  flex: 1;
  font-size: 30rpx;
  color: #2d2118;
}

.member-remove {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 36rpx;
  color: #b08060;
  border-radius: 50%;
  background: #f5ede4;
}

.member-remove:active {
  background: #e8d8c8;
}

/* 添加行 */
.add-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.add-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.add-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 32rpx;
  background: linear-gradient(135deg, #e07830, #c84848);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 36rpx;
  white-space: nowrap;
}

.add-btn:active {
  transform: scale(0.96);
}

/* 结果弹窗 */
.result-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.result-content {
  background: #fff;
  border-radius: 32rpx;
  padding: 64rpx 80rpx;
  text-align: center;
  animation: pop-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.result-emoji {
  font-size: 100rpx;
  line-height: 1;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 32rpx;
  color: #8a6850;
  margin-bottom: 12rpx;
}

.result-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #c84848;
  margin-bottom: 48rpx;
}

.result-close {
  background: linear-gradient(135deg, #e07830, #c84848);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 64rpx;
  border-radius: 48rpx;
  display: inline-block;
}

.result-close:active {
  transform: scale(0.96);
}

@keyframes pop-in {
  0%   { transform: scale(0.6); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
