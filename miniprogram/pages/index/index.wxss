.launch-page {
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at top right, rgba(59, 130, 246, 0.18), transparent 38%),
    linear-gradient(180deg, #f8fbff 0%, #eef3f8 100%);
}

.hero {
  width: 100%;
  padding: 56rpx 44rpx;
  text-align: center;
}

.hero-title {
  font-size: 54rpx;
  font-weight: 700;
  color: #0f172a;
}

.hero-desc {
  margin-top: 24rpx;
  color: #475569;
  line-height: 1.7;
}

.retry-btn {
  margin-top: 36rpx;
}
