.receipt-import-page {
  padding-bottom: 48rpx;
}

.hero-card {
  display: flex;
  gap: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #fff5e8 0%, #ffe3c6 100%);
  box-shadow: 0 8rpx 24rpx rgba(120, 80, 50, 0.06);
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #5a3420;
}

.hero-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8e664e;
}

.hero-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
}

.form-group {
  margin-top: 24rpx;
}

.group-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.group-bar {
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #e8845a 0%, #d4603e 100%);
}

.group-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a3828;
}

.group-count {
  margin-left: auto;
  font-size: 22rpx;
  color: #b0a090;
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item-card,
.form-card {
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(120, 80, 50, 0.05);
}

.item-top {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 10rpx;
}

.item-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  border: 2rpx solid #d8c7ba;
  color: #ffffff;
  text-align: center;
  line-height: 36rpx;
  font-size: 22rpx;
}

.item-check-on {
  background: #d36d3a;
  border-color: #d36d3a;
}

.item-index {
  font-size: 22rpx;
  color: #a58f82;
}

.item-remove {
  margin-left: auto;
  font-size: 22rpx;
  color: #c16d53;
}

.field {
  padding: 14rpx 0;
}

.field-row {
  display: flex;
  gap: 18rpx;
}

.field-half {
  flex: 1;
}

.field-label {
  font-size: 24rpx;
  color: #9a8a7e;
  margin-bottom: 12rpx;
}

.field-input {
  width: 100%;
  height: 78rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #faf7f3;
  font-size: 28rpx;
  color: #2d2118;
}

.field-divider {
  height: 2rpx;
  background: #f5efe8;
}

.add-btn {
  margin-top: 16rpx;
  height: 82rpx;
  border-radius: 20rpx;
  border: 2rpx dashed rgba(211, 109, 58, 0.35);
  background: rgba(232, 132, 90, 0.08);
  color: #c96232;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
}

.save-btn {
  margin-top: 28rpx;
}
