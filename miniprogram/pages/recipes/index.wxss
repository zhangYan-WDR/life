.recipes-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 0;
}

/* ===== Hero 头卡 ===== */
.hero-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ffd8b8 0%, #f5b888 50%, #e89060 100%);
  color: #ffffff;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(208, 130, 80, 0.2);
}

.hero-decor {
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-emoji {
  font-size: 56rpx;
}

.hero-content {
  flex: 1;
  min-width: 0;
}

.hero-eyebrow {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.85);
}

.hero-title {
  margin-top: 10rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #4a2818;
}

.hero-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(74, 40, 24, 0.7);
  line-height: 1.6;
}

/* ===== 快捷操作 ===== */
.quick-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.quick-btn {
  position: relative;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(120, 80, 50, 0.05);
  transition: transform 0.15s ease;
}

.quick-btn:active {
  transform: scale(0.98);
}

.quick-primary {
  background: linear-gradient(135deg, #e07850 0%, #d05a3a 100%);
}

.quick-primary .qb-title,
.quick-primary .qb-text {
  color: #ffffff;
}

.quick-primary .qb-text {
  opacity: 0.85;
}

.quick-primary .qb-icon {
  background: rgba(255, 255, 255, 0.25);
  color: #ffffff;
}

.quick-second {
  background: linear-gradient(135deg, #fff8ee 0%, #ffead0 100%);
}

.quick-plan {
  background: #faf7f3;
  opacity: 0.95;
}

.qb-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: rgba(208, 90, 58, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #d05a3a;
  flex-shrink: 0;
}

.qb-content {
  flex: 1;
  min-width: 0;
}

.qb-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3a2820;
}

.qb-text {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8a7568;
}

.qb-tag {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #ece4dc;
  color: #9a8478;
  font-size: 20rpx;
}

/* ===== 列表区 ===== */
.list-section {
  margin-top: 4rpx;
}

.group-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.group-bar {
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #e8845a, #d4603e);
}

.group-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a3828;
}

.group-count {
  margin-left: auto;
  font-size: 22rpx;
  color: #b0a090;
}

/* 搜索 */
.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 22rpx;
  margin-bottom: 16rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 14rpx rgba(120, 80, 50, 0.05);
}

.search-icon {
  font-size: 26rpx;
  color: #b0978a;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #4a3828;
  min-height: 40rpx;
}

.search-placeholder {
  color: #c5b5a4;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #f0e4d6;
  text-align: center;
  line-height: 36rpx;
  font-size: 28rpx;
  color: #8a7058;
}

/* 加载态 */
.loading-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 16rpx;
}

.dot-pulse {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #d4a080;
  animation: dotPulse 1.2s ease-in-out infinite;
}

.loading-text {
  font-size: 24rpx;
  color: #b0978a;
}

/* 菜谱列表 */
.recipe-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.recipe-card {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(120, 80, 50, 0.05);
  transition: transform 0.18s ease;
}

.recipe-card:active {
  transform: scale(0.98);
}

.recipe-cover {
  width: 110rpx;
  height: 110rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #fff4e6 0%, #ffe0c0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.recipe-cover-image {
  width: 100%;
  height: 100%;
}

.recipe-emoji {
  font-size: 52rpx;
}

.recipe-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.recipe-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.recipe-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #3a2820;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-badge {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #fff2e6;
  color: #c46c3a;
  font-size: 20rpx;
}

.recipe-note {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8a7568;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.recipe-meta {
  margin-top: 8rpx;
}

.meta-mini {
  font-size: 22rpx;
  color: #a0907e;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5a4a40;
}

.empty-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #a0907e;
}

.fab-spacer {
  height: 40rpx;
}

/* ===== 动画 ===== */
@keyframes dotPulse {
  0%, 100% { transform: scale(1); opacity: 0.4; }
  50% { transform: scale(1.5); opacity: 1; }
}
