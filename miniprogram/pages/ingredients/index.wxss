.ingredients-page {
  padding-bottom: 48rpx;
}

/* ===== 分组标题 ===== */
.group-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.group-bar {
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #e8845a 0%, #d4603e 100%);
}

.family-bar {
  background: linear-gradient(180deg, #6888e8 0%, #4868d0 100%);
}

.system-bar {
  background: linear-gradient(180deg, #a0b0c0 0%, #8898a8 100%);
}

.group-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a3828;
}

.group-count {
  font-size: 22rpx;
  color: #b0a090;
  margin-left: auto;
}

/* ===== 表单 ===== */
.form-section {
  margin-bottom: 32rpx;
}

.form-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 6rpx 24rpx rgba(120, 80, 50, 0.05);
}

.field {
  padding: 20rpx 0;
}

.field-label {
  font-size: 24rpx;
  color: #9a8a7e;
  margin-bottom: 12rpx;
}

.field-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: #faf7f3;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #2d2118;
  transition: border-color 0.2s ease, background 0.2s ease;
}

.field-input:focus {
  border-color: #e0845a;
  background: #fffcf9;
}

.field-divider {
  height: 2rpx;
  background: #f5efe8;
}

.save-btn {
  margin-top: 20rpx;
}

/* ===== 食材列表 ===== */
.list-section {
  margin-bottom: 28rpx;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-capsule {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  transition: transform 0.15s ease;
}

.tag-capsule:active {
  transform: scale(0.95);
}

.family-tag {
  background: linear-gradient(135deg, #eef2ff 0%, #e4ecff 100%);
}

.system-tag {
  background: #f5f0ea;
}

.tag-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #3a2820;
}

.tag-info {
  font-size: 22rpx;
  color: #a0907e;
  padding-left: 8rpx;
  border-left: 2rpx solid #d8d0c8;
}
