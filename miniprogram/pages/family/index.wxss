.family-page {
  background:
    radial-gradient(circle at top left, rgba(255, 210, 170, 0.3), transparent 30%),
    linear-gradient(180deg, #fef6ed 0%, #f8ece0 50%, #faf7f3 100%);
}

.family-hero {
  padding: 18rpx 6rpx 10rpx;
}

.hero-tag {
  color: #b07050;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  font-weight: 500;
}

.hero-title {
  margin-top: 20rpx;
  font-size: 48rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #3a2820;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #8a7568;
  line-height: 1.8;
}

/* ===== Tab 切换 ===== */
.tab-shell {
  margin-top: 32rpx;
}

.tab-switch {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.8);
  box-shadow: 0 8rpx 24rpx rgba(120, 80, 50, 0.06);
}

.tab-pill {
  height: 80rpx;
  border-radius: 999rpx;
  line-height: 80rpx;
  text-align: center;
  color: #8a7568;
  font-size: 28rpx;
  font-weight: 500;
  transition: color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
}

.tab-pill:active {
  transform: scale(0.96);
}

.tab-pill-active {
  background: linear-gradient(135deg, #e07850 0%, #d05a3a 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(208, 90, 58, 0.2);
}

/* ===== 表单面板 ===== */
.form-panel {
  margin-top: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 36rpx rgba(120, 80, 50, 0.06);
  animation: panelIn 0.3s ease;
}

.panel-top {
  margin-bottom: 28rpx;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3a2820;
}

.panel-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #8a7568;
  line-height: 1.7;
}

.field-label {
  font-size: 24rpx;
  color: #9a8478;
  font-weight: 500;
}

.family-input {
  margin-top: 14rpx;
  width: 100%;
  height: 92rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #faf7f3;
  border: 2rpx solid transparent;
  color: #3a2820;
  font-size: 28rpx;
  transition: border-color 0.2s ease, background 0.2s ease;
}

.family-input:focus {
  border-color: #e0845a;
  background: #fffcf9;
}

.code-input {
  letter-spacing: 10rpx;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
}

.form-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #ffffff;
  border: none;
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.form-btn:active {
  transform: scale(0.96);
  opacity: 0.88;
}

.create-btn {
  background: linear-gradient(135deg, #e07850 0%, #d05a3a 100%);
  box-shadow: 0 12rpx 28rpx rgba(208, 90, 58, 0.2);
}

.join-btn {
  background: linear-gradient(135deg, #6888e8 0%, #4868d0 100%);
  box-shadow: 0 12rpx 28rpx rgba(72, 104, 208, 0.2);
}

/* ===== 特性卡片 ===== */
.feature-strip {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 28rpx;
}

.feature-card {
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.75);
  box-shadow: 0 4rpx 16rpx rgba(120, 80, 50, 0.04);
  transition: transform 0.15s ease;
}

.feature-card:active {
  transform: scale(0.97);
}

.feature-emoji {
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3a2820;
}

.feature-text {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #8a7568;
}

/* ===== 动画 ===== */
@keyframes panelIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
