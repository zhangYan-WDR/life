page {
  min-height: 100%;
  background: #f3f5f7;
  color: #1f2937;
  font-size: 28rpx;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.section-desc {
  margin-top: 10rpx;
  color: #6b7280;
  line-height: 1.6;
}

.primary-btn {
  background: #2563eb;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 88rpx;
  height: 88rpx;
}

.secondary-btn {
  background: #e5edff;
  color: #1d4ed8;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 88rpx;
  height: 88rpx;
}

.ghost-btn {
  background: #ffffff;
  color: #1f2937;
  border: 2rpx solid #dbe2ea;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  height: 80rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  margin-top: 18rpx;
}

.label {
  color: #374151;
  font-size: 26rpx;
  font-weight: 500;
}
