page {
  min-height: 100%;
  background: #faf7f3;
  color: #1f2937;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.page-enter {
  animation: pageEnter 0.4s ease-out both;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 32rpx rgba(120, 80, 50, 0.06);
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(120, 80, 50, 0.08);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2d2118;
}

.section-desc {
  margin-top: 10rpx;
  color: #8a7d74;
  line-height: 1.6;
  font-size: 26rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.section-header::before {
  content: "";
  display: block;
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #e8845a 0%, #d4603e 100%);
}

.primary-btn {
  background: linear-gradient(135deg, #e07850 0%, #d05a3a 100%);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 92rpx;
  height: 92rpx;
  border: none;
  transition: transform 0.15s ease, opacity 0.15s ease;
}

.primary-btn:active {
  transform: scale(0.96);
  opacity: 0.88;
}

.secondary-btn {
  background: #fef0e8;
  color: #c4593a;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 88rpx;
  height: 88rpx;
  border: none;
  transition: transform 0.15s ease;
}

.secondary-btn:active {
  transform: scale(0.96);
}

.ghost-btn {
  background: #ffffff;
  color: #5a4a40;
  border: 2rpx solid #e8ddd5;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  height: 80rpx;
  transition: transform 0.15s ease, background 0.15s ease;
}

.ghost-btn:active {
  transform: scale(0.96);
  background: #faf5f0;
}

.input {
  width: 100%;
  height: 92rpx;
  background: #faf7f3;
  border: 2rpx solid transparent;
  border-radius: 20rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #2d2118;
  transition: border-color 0.2s ease, background 0.2s ease;
}

.input-focus {
  border-color: #e0845a;
  background: #fffcf9;
}

.label {
  color: #5a4a40;
  font-size: 26rpx;
  font-weight: 500;
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
