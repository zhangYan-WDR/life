.ip-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #faf7f3;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
}
.ip-text {
  flex: 1;
  font-size: 28rpx;
  color: #2d2118;
}
.ip-placeholder {
  color: #a89c93;
}
.ip-arrow {
  color: #b89a80;
  font-size: 36rpx;
  margin-left: 12rpx;
}

.ip-mask {
  position: fixed;
  inset: 0;
  background: rgba(40, 28, 20, 0.45);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  animation: ipMaskIn 0.18s ease-out both;
}
.ip-sheet {
  width: 100%;
  height: 75vh;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  display: flex;
  flex-direction: column;
  animation: ipSheetIn 0.22s ease-out both;
  overflow: hidden;
}
.ip-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
}
.ip-sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d2118;
}
.ip-sheet-close {
  font-size: 44rpx;
  color: #8a7d74;
  line-height: 1;
  padding: 0 8rpx;
}
.ip-search {
  position: relative;
  margin: 0 32rpx 16rpx;
}
.ip-search-input {
  width: 100%;
  height: 80rpx;
  background: #faf7f3;
  border-radius: 16rpx;
  padding: 0 60rpx 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #2d2118;
}
.ip-search-clear {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 50%;
  background: #e8ddd5;
  color: #5a4a40;
  font-size: 28rpx;
}
.ip-list {
  flex: 1;
  height: 0;
  min-height: 0;
  padding: 0 16rpx 24rpx;
  box-sizing: border-box;
}
.ip-searching {
  padding: 16rpx 24rpx 8rpx;
  color: #a89c93;
  font-size: 24rpx;
}
.ip-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  margin: 0 8rpx;
  border-radius: 16rpx;
}
.ip-item:active {
  background: #faf5f0;
}
.ip-item-active {
  background: #fef0e8;
}
.ip-item-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}
.ip-item-name {
  font-size: 30rpx;
  color: #2d2118;
}
.ip-item-meta {
  font-size: 22rpx;
  color: #9a8d84;
}
.ip-item-unit {
  font-size: 24rpx;
  color: #8a7d74;
  margin-left: 16rpx;
}
.ip-empty {
  padding: 60rpx 0;
  text-align: center;
  color: #a89c93;
  font-size: 26rpx;
}
.ip-loading {
  padding: 24rpx;
  text-align: center;
  color: #a89c93;
  font-size: 24rpx;
}
.ip-sheet-back {
  font-size: 44rpx;
  color: #8a7d74;
  line-height: 1;
  padding: 0 12rpx 0 0;
}
.ip-section {
  margin-top: 12rpx;
}
.ip-section-title {
  display: block;
  padding: 16rpx 24rpx 8rpx;
  font-size: 24rpx;
  color: #a89c93;
}
.ip-cat {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 24rpx;
  margin: 0 8rpx;
  border-radius: 16rpx;
}
.ip-cat:active {
  background: #faf5f0;
}
.ip-cat-name {
  font-size: 30rpx;
  color: #2d2118;
}
.ip-cat-count {
  font-size: 24rpx;
  color: #b89a80;
}
.ip-subcat .ip-cat-name {
  font-size: 28rpx;
}

@keyframes ipMaskIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes ipSheetIn {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
